# =============================================================================
# Git Attributes for Monochrome Flatpak
# =============================================================================

# -----------------------------------------------------------------------------
# Line Endings
# -----------------------------------------------------------------------------
* text=auto

# Explicitly declare text files
*.sh text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.desktop text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.flatpak text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# -----------------------------------------------------------------------------
# Screenshots - Important for Flathub submission
# -----------------------------------------------------------------------------
screenshots/*.png binary export-ignore

# Icons
flathub/icons/*.svg export-ignore

# -----------------------------------------------------------------------------
# Submodules
# -----------------------------------------------------------------------------
monochrome/ export-ignore

# -----------------------------------------------------------------------------
# Documentation - Include in exports
# -----------------------------------------------------------------------------
README.md export-ignore
LICENSE export-ignore
CONTRIBUTING.md export-ignore

# -----------------------------------------------------------------------------
# Rapports de correction - Keep for reference
# -----------------------------------------------------------------------------
Rapport-Correction/* text eol=lf
